.DS_Store
Thumbs.db

# Nested .gitignore in frontend/ covers node_modules, dist, .svelte-kit, yarn caches.

# Rust / WASM core build artifacts. core/pkg is generated by `wasm-pack build` and
# consumed by the frontend via a link: dependency; never commit it.
/target/
core/pkg/

# The backend's runtime document folder (`just backend`) — user .svg files, not source.
/docs/

# The backend's SQLite database (Phase C) — runtime data, not source.
nib.db
nib.db-shm
nib.db-wal

